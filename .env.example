# Web
NEXT_PUBLIC_APP_NAME=ATRIA
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Recomendado para produccion: variable solo del lado servidor en Next.js
API_BASE_URL=http://localhost:4000/api
# Compatibilidad local / fallback
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# API
APP_NAME=legal-api
APP_ORIGINS=http://localhost:3000,http://localhost:3001
PORT=4000
NODE_ENV=development
JWT_SECRET=colocar_un_secreto_seguro
JWT_REFRESH_SECRET=colocar_otro_secreto_seguro
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/legal_db?schema=public
AWS_REGION=us-east-1
AWS_S3_BUCKET=pendiente-configurar
AWS_ACCESS_KEY_ID=pendiente-configurar
AWS_SECRET_ACCESS_KEY=pendiente-configurar
SEED_ADMIN_EMAIL=admin@estudiolegal.local
SEED_ADMIN_PASSWORD=Admin123!
SEED_TEAM_DATA=true
SEED_DEMO_DATA=false
